{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "warn",
    "perf": "warn",
    "suspicious": "warn",
    "pedantic": "allow"
  },
  "rules": {
    "eslint/no-unused-vars": "error",
    "react/jsx-no-target-blank": "error",
    "react-hooks/rules-of-hooks": "error"
  },
  "ignorePatterns": ["dist/**", "coverage/**", "vendor/**", "test/snapshots/**"]
}
